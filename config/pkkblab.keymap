#define ZMK_POINTING_DEFAULT_MOVE_VAL 2500  // default: 600
#define ZMK_POINTING_DEFAULT_SCRL_VAL 40    // default: 10

#include <behaviors.dtsi>
#include <dt-bindings/zmk/bt.h>
#include <dt-bindings/zmk/ext_power.h>
#include <dt-bindings/zmk/keys.h>
#include <dt-bindings/zmk/outputs.h>
#include <dt-bindings/zmk/pointing.h>

/ {
    behaviors {
        taptap: taptap {
            compatible = "zmk,behavior-hold-tap";
            label = "TAPTAP";
            bindings = <&kp>, <&kp>;

            #binding-cells = <2>;
            tapping-term-ms = <200>;
            quick-tap-ms = <180>;
            require-prior-idle-ms = <150>;
            flavor = "tap-preferred";
        };

        holdhold: holdhold {
            compatible = "zmk,behavior-hold-tap";
            label = "HOLDHOLD";
            bindings = <&mo>, <&kp>;

            #binding-cells = <2>;
            flavor = "tap-unless-interrupted";
            require-prior-idle-ms = <150>;
            tapping-term-ms = <200>;
            retro-tap;
            quick-tap-ms = <180>;
        };

        momotap: momotap {
            compatible = "zmk,behavior-hold-tap";
            label = "MOMOTAP";
            bindings = <&mo>, <&kp>;

            #binding-cells = <2>;
            tapping-term-ms = <200>;
            quick-tap-ms = <180>;
            require-prior-idle-ms = <150>;
            flavor = "tap-preferred";
        };
    };

    combos {
        compatible = "zmk,combos";

        news {
            bindings = <&kp N>;
            key-positions = <10 11>;
        };

        desk {
            bindings = <&kp LG(D)>;
            key-positions = <11 12>;
        };

        create {
            bindings = <&kp LG(E)>;
            key-positions = <12 13>;
        };

        altf4 {
            bindings = <&kp RA(F4)>;
            key-positions = <13 14>;
        };

        guilock {
            bindings = <&kp LG(L)>;
            key-positions = <23 24>;
        };

        backspace {
            bindings = <&kp BACKSPACE>;
            key-positions = <8 9>;
        };

        qw {
            bindings = <&kp ESC>;
            key-positions = <0 1>;
        };

        bootloader {
            bindings = <&bootloader>;
            key-positions = <3 2 1 0>;
        };

        boot {
            bindings = <&bootloader>;
            key-positions = <9 8 7 6>;
        };

        toto {
            bindings = <&kp LG(TAB)>;
            key-positions = <1 2>;
        };
    };

    keymap {
        compatible = "zmk,keymap";

        default_layer {
            bindings = <
&to 3        &cji CJI_I  &cji CJI_DOT  &cji CJI_EU     &cji CJI_BSPC   &none  &none  &none  &none  &none
&to 3        &cji CJI_G  &cji CJI_N    &cji CJI_D      &cji CJI_ENTER  &none  &none  &none  &none  &none
&to 1        &cji CJI_B  &cji CJI_S    &cji CJI_J      &to 3           &none  &none  &none  &none  &none
&none        &none       &cji CJI_O    &cji CJI_SPACE  &none           &none  &none  &none  &none  &none
            >;
        };

        layer_1 {
            bindings = <
&kp ESC         &kp LA(NUMBER_1)  &kp LA(NUMBER_3)  &kp MINUS           &kp EQUAL   &kp LEFT_ARROW     &kp RIGHT_ARROW  &kp UP_ARROW   &kp DOWN_ARROW  &kp BACKSPACE
&kp LG(TAB)     &kp LC(N)         &kp LG(D)         &kp LG(E)           &kp LA(F4)  &kp HOME           &kp END          &kp SEMICOLON  &kp APOS        &kp ENTER
&kp CAPS        &kp LC(A)         &kp LC(C)         &kp LC(V)           &kp ENTER   &kp C_VOLUME_DOWN  &kp C_VOLUME_UP  &kp SEMI       &kp APOS        &kp RSHFT
&kp LEFT_SHIFT  &kp LGUI          &kp LALT          &taptap LSHIFT TAB  &kp SPACE   &kp BACKSPACE      &kp SPACE        &kp LALT       &kp LGUI        &kp DEL
            >;
        };

        layer_2 {
            bindings = <
&kp N1        &kp N2        &kp N3        &kp N4              &kp N5          &kp N6  &kp N7  &kp N8    &kp N9   &kp N0
&bt BT_SEL 0  &bt BT_SEL 1  &bt BT_SEL 2  &bt BT_SEL 3        &bt BT_SEL 4    &kp F1  &kp F2  &kp F3    &kp F4   &kp F5
&bt BT_CLR    &mkp MB3      &mkp MB2      &msc SCRL_DOWN      &bt BT_CLR_ALL  &kp F6  &kp F7  &kp F8    &kp F9   &kp F10
&kp LSHFT     &kp LGUI      &kp LALT      &taptap LSHIFT TAB  &mkp MB1        &trans  &trans  &kp LALT  &kp F11  &kp F12
            >;
        };

        layer_3 {
            bindings = <
&kp ESC    &kp F1    &kp F2    &kp F3              &kp F4     &bt BT_SEL 0  &bt BT_SEL 1  &bt BT_SEL 2  &bt BT_SEL 3       &bt BT_SEL 4
&kp LSHFT  &kp F5    &kp F6    &kp F7              &kp F8     &trans        &trans        &trans        &bt BT_CLR         &out OUT_TOG
&kp CAPS   &kp F9    &kp F10   &kp F11             &kp F12    &trans        &trans        &trans        &trans             &trans
&kp LCTRL  &kp LGUI  &kp LALT  &taptap LSHIFT TAB  &kp ENTER  &trans        &trans        &trans        &ext_power EP_OFF  &ext_power EP_ON
            >;
        };

        layer_4 {
            bindings = <
&kp N1  &kp N2  &kp N3  &kp N4  &kp N5  &kp N6  &kp N7  &kp N8  &kp N9  &kp N0
&kp Q   &kp W   &kp E   &trans  &trans  &trans  &trans  &trans  &trans  &trans
&trans  &trans  &trans  &trans  &trans  &trans  &trans  &trans  &trans  &trans
&trans  &trans  &trans  &trans  &trans  &trans  &trans  &trans  &trans  &trans
            >;
        };
    };
};
